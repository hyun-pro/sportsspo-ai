# BallPredict Backend 환경변수

# 서버
PORT=8000
NODE_ENV=production

# 인증
JWT_SECRET=your-strong-secret-key-here

# CORS (콤마 구분)
CORS_ORIGINS=https://ballpredict.vercel.app,https://your-custom-domain.com

# 데이터 동기화 주기 (밀리초, 기본 30분)
SYNC_INTERVAL_MS=1800000

# Stripe (구독 기능)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
